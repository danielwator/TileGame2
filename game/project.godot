; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.

config_version=5

[application]

config/name="AEONS"
config/description="A globe-spanning grand strategy game across the ages."
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.4", "Forward Plus")

[autoload]

Data="*res://scripts/data_loader.gd"

[display]

window/size/viewport_width=1600
window/size/viewport_height=900
window/size/mode=2

[input_devices]

pointing/emulate_touch_from_mouse=false

[rendering]

renderer/rendering_method="forward_plus"
anti_aliasing/quality/msaa_3d=2
environment/defaults/default_clear_color=Color(0.02, 0.027, 0.05, 1)
